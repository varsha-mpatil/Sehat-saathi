rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role']) &&
               data.uid == request.auth.uid &&
               data.email is string &&
               data.role in ['patient', 'doctor'] &&
               (!('specialty' in data) || data.specialty is string) &&
               (!('bio' in data) || data.bio is string);
      }

      allow get: if isSignedIn(); // Allow searching for doctors
      allow list: if isSignedIn() && resource.data.role == 'doctor'; // Allow listing doctors for telemedicine
      
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'specialty', 'bio', 'updatedAt'])
      ) && incoming().updatedAt == request.time;
    }

    // --- Admins Collection (Optional but recommended) ---
    match /admins/{adminId} {
      allow read: if isSignedIn() && isOwner(adminId);
    }
  }
}
